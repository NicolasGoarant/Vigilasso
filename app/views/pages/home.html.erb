<% content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Source+Sans+3:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    .font-display { font-family: 'Fraunces', Georgia, serif; font-optical-sizing: auto; }
    .font-body    { font-family: 'Source Sans 3', system-ui, sans-serif; }
    .home-grain {
      background-image: radial-gradient(circle at 1px 1px, rgba(15,23,42,0.04) 1px, transparent 0);
      background-size: 24px 24px;
    }
  </style>
<% end %>

<div class="font-body -mx-6 -my-6">

  <%# ===== HERO ===== %>
  <section class="relative bg-gradient-to-b from-slate-50 to-white home-grain">
    <div class="max-w-5xl mx-auto px-6 pt-20 pb-24">
      <div class="inline-flex items-center gap-2 text-xs font-medium text-indigo-700 bg-indigo-50 border border-indigo-100 px-3 py-1 rounded-full mb-8">
        <span class="w-1.5 h-1.5 bg-indigo-600 rounded-full"></span>
        Outil d'aide à la décision pour les collectivités
      </div>

      <h1 class="font-display text-5xl md:text-6xl font-500 text-slate-900 leading-[1.05] tracking-tight mb-8 max-w-3xl">
        Anticiper la fragilité des associations <em class="text-indigo-700 font-400 italic">avant</em> qu'elle ne devienne une crise.
      </h1>

      <p class="text-xl text-slate-600 leading-relaxed max-w-2xl mb-10">
        Vigil'Asso analyse les comptes annuels des associations subventionnées de votre territoire et identifie celles dont la santé financière mérite votre attention en priorité.
      </p>

      <div class="flex flex-wrap items-center gap-3">
        <%= link_to new_association_path, class: "inline-flex items-center gap-2 bg-indigo-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-indigo-700 transition-colors shadow-sm" do %>
          Importer des comptes
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        <% end %>
        <%= link_to "Explorer le tableau de bord", associations_path, class: "inline-flex items-center gap-2 text-slate-700 px-6 py-3 rounded-lg font-medium hover:bg-slate-100 transition-colors" %>
      </div>
    </div>
  </section>

  <%# ===== LE PROBLÈME ===== %>
  <section class="bg-white border-t border-slate-100">
    <div class="max-w-5xl mx-auto px-6 py-20">
      <div class="grid md:grid-cols-12 gap-12 items-start">
        <div class="md:col-span-5">
          <p class="text-sm font-semibold text-indigo-700 uppercase tracking-wider mb-3">Le constat</p>
          <h2 class="font-display text-3xl md:text-4xl font-500 text-slate-900 leading-tight tracking-tight">
            Une défaillance d'association est rarement une surprise.
          </h2>
        </div>
        <div class="md:col-span-7 space-y-6 text-slate-600 text-lg leading-relaxed">
          <p>
            Chaque année en France, près de <strong class="text-slate-900 font-semibold">900 associations subventionnées</strong> entrent en redressement ou liquidation judiciaire. Pour les collectivités qui les financent, c'est une perte de service public, une difficulté humaine pour les salariés et bénévoles, parfois un risque réputationnel.
          </p>
          <p>
            Les signes financiers sont presque toujours présents <em>avant</em> la chute, dans les comptes annuels publiés au Journal officiel. Mais aucun service Vie Associative n'a le temps de lire ligne à ligne les bilans de 200 dossiers chaque année.
          </p>
        </div>
      </div>
    </div>
  </section>

  <%# ===== LA PROPOSITION DE VALEUR (chiffre clé) ===== %>
  <section class="bg-slate-900 text-white">
    <div class="max-w-5xl mx-auto px-6 py-24">
      <p class="text-sm font-semibold text-indigo-300 uppercase tracking-wider mb-4">Notre engagement de fiabilité</p>
      <p class="font-display text-3xl md:text-5xl font-400 leading-[1.2] tracking-tight max-w-4xl">
        Sur un portefeuille de 200 associations, Vigil'Asso signale environ <span class="text-indigo-300 font-500">25 dossiers à examiner en priorité</span>, dont <span class="underline decoration-indigo-400 decoration-2 underline-offset-4">7 sur 10</span> confirment effectivement une fragilité financière.
      </p>
      <p class="text-slate-400 text-sm mt-8 max-w-2xl">
        Performance mesurée sur un échantillon équilibré de 212 cas réels (associations défaillantes vs. saines), comptes annuels 2020-2024. Indicateurs : précision 71 %, rappel 85 % au seuil standard.
      </p>
    </div>
  </section>

  <%# ===== COMMENT ÇA MARCHE ===== %>
  <section class="bg-white border-t border-slate-100">
    <div class="max-w-5xl mx-auto px-6 py-20">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-indigo-700 uppercase tracking-wider mb-3">En pratique</p>
        <h2 class="font-display text-3xl md:text-4xl font-500 text-slate-900 leading-tight tracking-tight">
          Trois étapes, du PDF à la décision.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-10">
        <div>
          <div class="font-display text-5xl text-indigo-600 font-500 mb-4">01</div>
          <h3 class="font-display text-xl font-600 text-slate-900 mb-3">Importer</h3>
          <p class="text-slate-600 leading-relaxed">
            Glissez-déposez les comptes annuels au format PDF (publiés par les associations au Journal officiel ou transmis par elles directement).
          </p>
        </div>
        <div>
          <div class="font-display text-5xl text-indigo-600 font-500 mb-4">02</div>
          <h3 class="font-display text-xl font-600 text-slate-900 mb-3">Analyser</h3>
          <p class="text-slate-600 leading-relaxed">
            Vigil'Asso extrait automatiquement les indicateurs financiers clés (rentabilité, fonds propres, trésorerie, autonomie) et calcule un score de risque.
          </p>
        </div>
        <div>
          <div class="font-display text-5xl text-indigo-600 font-500 mb-4">03</div>
          <h3 class="font-display text-xl font-600 text-slate-900 mb-3">Prioriser</h3>
          <p class="text-slate-600 leading-relaxed">
            Le tableau de bord classe vos associations de A (saine) à E (fragile). Vos équipes savent où porter leur vigilance.
          </p>
        </div>
      </div>
    </div>
  </section>

  <%# ===== POUR QUI ===== %>
  <section class="bg-slate-50 border-t border-slate-100">
    <div class="max-w-5xl mx-auto px-6 py-20">
      <div class="grid md:grid-cols-12 gap-12">
        <div class="md:col-span-5">
          <p class="text-sm font-semibold text-indigo-700 uppercase tracking-wider mb-3">Pour qui</p>
          <h2 class="font-display text-3xl md:text-4xl font-500 text-slate-900 leading-tight tracking-tight">
            Un outil de gouvernance, pas un outil de contrôle.
          </h2>
        </div>
        <div class="md:col-span-7 space-y-8">
          <div class="border-l-2 border-indigo-200 pl-6">
            <h3 class="font-display text-xl font-600 text-slate-900 mb-2">Élus délégués à la vie associative</h3>
            <p class="text-slate-600 leading-relaxed">
              Anticipez les difficultés des structures que vous soutenez. Sécurisez l'usage des deniers publics. Évitez les défaillances soudaines qui fragilisent les politiques publiques portées par le tissu associatif.
            </p>
          </div>
          <div class="border-l-2 border-indigo-200 pl-6">
            <h3 class="font-display text-xl font-600 text-slate-900 mb-2">Services Vie Associative et DAF</h3>
            <p class="text-slate-600 leading-relaxed">
              Concentrez votre temps de vérification sur une short-list priorisée. Engagez le dialogue financier avec les associations en zone d'attention avant que la situation ne devienne irréversible.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <%# ===== CTA FINAL ===== %>
  <section class="bg-white border-t border-slate-100">
    <div class="max-w-3xl mx-auto px-6 py-20 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-500 text-slate-900 leading-tight tracking-tight mb-6">
        Tester Vigil'Asso sur vos données.
      </h2>
      <p class="text-lg text-slate-600 leading-relaxed mb-10 max-w-xl mx-auto">
        L'outil est en phase d'expérimentation auprès de collectivités pilotes. Importez quelques comptes pour évaluer la pertinence sur votre territoire.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <%= link_to new_association_path, class: "inline-flex items-center gap-2 bg-indigo-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-indigo-700 transition-colors shadow-sm" do %>
          Importer un premier dossier
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        <% end %>
        <a href="mailto:nicolas@vigilasso.fr" class="inline-flex items-center gap-2 text-slate-700 px-6 py-3 rounded-lg font-medium hover:bg-slate-100 transition-colors">
          Échanger avec l'équipe
        </a>
      </div>
    </div>
  </section>

  <%# ===== FOOTER MINIMAL ===== %>
  <footer class="bg-slate-50 border-t border-slate-200">
    <div class="max-w-5xl mx-auto px-6 py-10 flex flex-wrap items-center justify-between gap-4 text-sm text-slate-500">
      <div>
        <span class="font-display font-600 text-slate-700">Vigil'Asso</span> — outil d'aide à la décision pour les collectivités
      </div>
      <div class="flex items-center gap-6">
        <a href="mailto:nicolas@vigilasso.fr" class="hover:text-slate-900 transition-colors">Contact</a>
        <%= link_to "Tableau de bord", associations_path, class: "hover:text-slate-900 transition-colors" %>
      </div>
    </div>
  </footer>

</div>
