<% content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    .font-display { font-family: 'Fraunces', Georgia, serif; font-optical-sizing: auto; }
    .font-body    { font-family: 'Source Sans 3', system-ui, sans-serif; }
    .vignette-card { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .vignette-card:hover { transform: translateY(-2px); box-shadow: 0 10px 30px -10px rgba(15,23,42,0.15); }
    .hero-bg {
      background-image:
        linear-gradient(135deg, rgba(15,23,42,0.92) 0%, rgba(30,41,59,0.85) 60%, rgba(67,56,202,0.75) 100%),
        url('https://images.unsplash.com/photo-1577962917302-cd874c4e31d2?auto=format&fit=crop&w=2000&q=80');
      background-size: cover;
      background-position: center;
    }
    .full-bleed {
      width: 100vw;
      position: relative;
      left: 50%;
      right: 50%;
      margin-left: -50vw;
      margin-right: -50vw;
    }
  </style>
<% end %>

<div class="font-body -mx-6 -my-6 text-[17px]">

  <%# ===== HERO ===== %>
  <section class="hero-bg full-bleed">
    <div class="max-w-6xl mx-auto px-6 pt-20 pb-24 grid md:grid-cols-12 gap-10 items-center relative">
      <div class="md:col-span-7 text-white">
        <div class="inline-flex items-center gap-2 text-xs font-semibold text-indigo-100 bg-indigo-900/40 backdrop-blur border border-indigo-400/30 px-3 py-1.5 rounded-full mb-8 tracking-wide uppercase">
          <span class="w-1.5 h-1.5 bg-indigo-300 rounded-full"></span>
          Aide à la décision · Collectivités
        </div>

        <h1 class="font-display text-5xl md:text-6xl font-medium leading-[1.05] tracking-tight mb-8">
          Anticiper la fragilité des associations <em class="text-indigo-300 font-normal italic">avant</em> qu'elle ne devienne une crise.
        </h1>

        <p class="text-xl text-slate-200 leading-relaxed mb-10 max-w-2xl">
          Téléversez les comptes annuels d'une association : Vigil'Asso évalue sa santé financière et vous indique s'il y a lieu d'être vigilant.
        </p>

        <div class="flex flex-wrap items-center gap-3">
          <%= link_to new_association_path, class: "inline-flex items-center gap-2 bg-white text-slate-900 px-6 py-3.5 rounded-lg font-semibold hover:bg-slate-100 transition-colors shadow-lg" do %>
            Tester avec un PDF
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          <% end %>
          <a href="#observatoire" class="inline-flex items-center gap-2 text-white px-6 py-3.5 rounded-lg font-semibold hover:bg-white/10 transition-colors backdrop-blur border border-white/20">
            Découvrir l'observatoire
          </a>
        </div>
      </div>

      <div class="md:col-span-5">
        <div class="bg-white rounded-2xl shadow-2xl p-2">
          <svg viewBox="0 0 400 320" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto rounded-xl">
            <defs>
              <linearGradient id="cardGrad" x1="0" x2="0" y1="0" y2="1">
                <stop offset="0%" stop-color="#ffffff"/>
                <stop offset="100%" stop-color="#f8fafc"/>
              </linearGradient>
              <linearGradient id="riskGrad" x1="0" x2="1" y1="0" y2="0">
                <stop offset="0%" stop-color="#10b981"/>
                <stop offset="50%" stop-color="#f59e0b"/>
                <stop offset="100%" stop-color="#ef4444"/>
              </linearGradient>
            </defs>
            <rect x="0" y="0" width="400" height="320" rx="12" fill="url(#cardGrad)"/>
            <text x="24" y="36" font-family="Fraunces, serif" font-size="16" font-weight="600" fill="#0f172a">Centre Social Les Tilleuls</text>
            <text x="24" y="56" font-family="Source Sans 3, sans-serif" font-size="12" fill="#94a3b8">Subventions 2024 · Tranche 11-49 salariés</text>
            <text x="24" y="95" font-family="Source Sans 3, sans-serif" font-size="10" font-weight="600" fill="#475569" letter-spacing="0.5">SCORE DE RISQUE</text>
            <rect x="24" y="105" width="352" height="10" rx="5" fill="#f1f5f9"/>
            <rect x="24" y="105" width="252" height="10" rx="5" fill="url(#riskGrad)"/>
            <circle cx="276" cy="110" r="9" fill="#ffffff" stroke="#0f172a" stroke-width="2.5"/>
            <text x="24" y="135" font-family="Source Sans 3, sans-serif" font-size="10" fill="#94a3b8">A</text>
            <text x="108" y="135" font-family="Source Sans 3, sans-serif" font-size="10" fill="#94a3b8">B</text>
            <text x="192" y="135" font-family="Source Sans 3, sans-serif" font-size="10" fill="#94a3b8">C</text>
            <text x="270" y="135" font-family="Source Sans 3, sans-serif" font-size="10" font-weight="700" fill="#0f172a">D</text>
            <text x="360" y="135" font-family="Source Sans 3, sans-serif" font-size="10" fill="#94a3b8">E</text>
            <line x1="24" y1="160" x2="376" y2="160" stroke="#f1f5f9" stroke-width="1"/>
            <text x="24" y="190" font-family="Source Sans 3, sans-serif" font-size="13" fill="#64748b">Trésorerie</text>
            <text x="376" y="190" text-anchor="end" font-family="Source Sans 3, sans-serif" font-size="13" font-weight="600" fill="#ef4444">−42 %</text>
            <text x="24" y="215" font-family="Source Sans 3, sans-serif" font-size="13" fill="#64748b">Fonds propres</text>
            <text x="376" y="215" text-anchor="end" font-family="Source Sans 3, sans-serif" font-size="13" font-weight="600" fill="#f59e0b">−18 %</text>
            <text x="24" y="240" font-family="Source Sans 3, sans-serif" font-size="13" fill="#64748b">Résultat exploitation</text>
            <text x="376" y="240" text-anchor="end" font-family="Source Sans 3, sans-serif" font-size="13" font-weight="600" fill="#ef4444">−87 k€</text>
            <rect x="24" y="270" width="352" height="30" rx="8" fill="#fef3c7"/>
            <circle cx="40" cy="285" r="4" fill="#f59e0b"/>
            <text x="52" y="290" font-family="Source Sans 3, sans-serif" font-size="13" font-weight="600" fill="#92400e">À examiner en priorité</text>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <%# ===== LE PROBLÈME ===== %>
  <section class="bg-white border-t border-slate-100">
    <div class="max-w-5xl mx-auto px-6 py-20">
      <div class="grid md:grid-cols-12 gap-12 items-start">
        <div class="md:col-span-5">
          <p class="text-sm font-semibold text-indigo-700 uppercase tracking-wider mb-3">Le constat</p>
          <h2 class="font-display text-4xl md:text-5xl font-medium text-slate-900 leading-tight tracking-tight">
            Une défaillance d'association est rarement une surprise.
          </h2>
        </div>
        <div class="md:col-span-7 space-y-5 text-slate-600 text-lg leading-relaxed">
          <p>
            Chaque année en France, près de <strong class="text-slate-900 font-semibold">900 associations subventionnées</strong> entrent en redressement ou liquidation judiciaire. Pour les collectivités qui les financent, c'est une perte de service public, une difficulté humaine pour les salariés et bénévoles, parfois un risque réputationnel.
          </p>
          <p>
            Les signes financiers sont presque toujours présents <em>avant</em> la chute, dans les comptes annuels publiés au Journal officiel. Mais aucun service Vie Associative n'a le temps de lire ligne à ligne les bilans de chaque dossier.
          </p>
        </div>
      </div>
    </div>
  </section>

  <%# ===== TROIS CAS ===== %>
  <section class="bg-slate-50 border-t border-slate-100">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <div class="text-center mb-14">
        <p class="text-sm font-semibold text-indigo-700 uppercase tracking-wider mb-3">Quand l'inattendu arrive</p>
        <h2 class="font-display text-4xl md:text-5xl font-medium text-slate-900 leading-tight tracking-tight max-w-3xl mx-auto">
          Trois récits qui rappellent l'enjeu d'une vigilance partagée.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <article class="vignette-card bg-white rounded-2xl border border-slate-200 overflow-hidden">
          <div class="h-48 relative overflow-hidden">
            <img src="https://images.unsplash.com/photo-1568667256549-094345857637?auto=format&fit=crop&w=800&q=75" alt="Façade d'un centre culturel" class="w-full h-full object-cover">
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/40 to-transparent"></div>
          </div>
          <div class="p-6">
            <p class="text-xs font-semibold text-rose-600 uppercase tracking-wider mb-3">Grand Est · Juin 2025</p>
            <h3 class="font-display text-xl font-semibold text-slate-900 leading-snug mb-3">
              « Un centre culturel emblématique liquidé après 30 ans d'activité. »
            </h3>
            <p class="text-slate-600 text-sm leading-relaxed mb-4">
              Le tribunal a prononcé la liquidation malgré les efforts de redressement engagés depuis février. <strong class="text-slate-900">29 salariés licenciés.</strong> L'exercice précédent affichait déjà un déficit de 280 000 €.
            </p>
            <p class="text-xs text-slate-400 italic">Cas inspiré de faits récents</p>
          </div>
        </article>

        <article class="vignette-card bg-white rounded-2xl border border-slate-200 overflow-hidden">
          <div class="h-48 relative overflow-hidden">
            <img src="https://images.unsplash.com/photo-1582213782179-e0d53f98f2ca?auto=format&fit=crop&w=800&q=75" alt="Réunion d'équipe associative" class="w-full h-full object-cover">
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/40 to-transparent"></div>
          </div>
          <div class="p-6">
            <p class="text-xs font-semibold text-rose-600 uppercase tracking-wider mb-3">Île-de-France · Mai 2025</p>
            <h3 class="font-display text-xl font-semibold text-slate-900 leading-snug mb-3">
              « 355 000 € d'impayés Urssaf : la médiation locale s'effondre. »
            </h3>
            <p class="text-slate-600 text-sm leading-relaxed mb-4">
              Présente depuis 2017 dans les quartiers de la commune, l'association accompagnait 200 jeunes par an. <strong class="text-slate-900">Subventions municipales : jusqu'à 300 000 € par an.</strong> Les charges sociales n'étaient plus payées depuis 18 mois.
            </p>
            <p class="text-xs text-slate-400 italic">Cas inspiré de faits récents</p>
          </div>
        </article>

        <article class="vignette-card bg-white rounded-2xl border border-slate-200 overflow-hidden">
          <div class="h-48 relative overflow-hidden">
            <img src="https://images.unsplash.com/photo-1521587760476-6c12a4b040da?auto=format&fit=crop&w=800&q=75" alt="Bibliothèque associative" class="w-full h-full object-cover">
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/40 to-transparent"></div>
          </div>
          <div class="p-6">
            <p class="text-xs font-semibold text-rose-600 uppercase tracking-wider mb-3">Nouvelle-Aquitaine · Octobre 2025</p>
            <h3 class="font-display text-xl font-semibold text-slate-900 leading-snug mb-3">
              « Du gâchis : l'association de lutte contre l'illettrisme liquidée. »
            </h3>
            <p class="text-slate-600 text-sm leading-relaxed mb-4">
              Créée pour permettre à des centaines de personnes d'apprendre à lire et à écrire. <strong class="text-slate-900">La fin était brutale mais peut-être pas imprévue.</strong> Les administrateurs n'ont été informés qu'à la dernière minute.
            </p>
            <p class="text-xs text-slate-400 italic">Cas inspiré de faits récents</p>
          </div>
        </article>
      </div>

      <p class="text-center text-sm text-slate-500 mt-10 max-w-2xl mx-auto">
        Trois cas, trois territoires, trois moments où une vigilance financière en amont aurait pu changer le cours des choses.
      </p>
    </div>
  </section>

  <%# ===== ENGAGEMENT ===== %>
  <section class="bg-slate-900 text-white">
    <div class="max-w-6xl mx-auto px-6 py-24 grid md:grid-cols-12 gap-12 items-center">
      <div class="md:col-span-7">
        <p class="text-sm font-semibold text-indigo-300 uppercase tracking-wider mb-4">Notre engagement de fiabilité</p>
        <p class="font-display text-3xl md:text-5xl font-normal leading-[1.2] tracking-tight">
          Modèle entraîné sur <span class="underline decoration-indigo-400 decoration-2 underline-offset-4">107 défaillances</span> réelles publiées au BODACC. Validé contre les chambres régionales des comptes : <span class="underline decoration-indigo-400 decoration-2 underline-offset-4">96 % de rappel</span>, 71 % de précision.
        </p>
        <p class="text-slate-400 text-sm mt-8 max-w-2xl leading-relaxed">
          Validation externe sur 38 cas exploitables tirés de 162 rapports CRC, au seuil d'alerte recommandé (niveaux C, D ou E). Intervalles de confiance ±15 points à cette taille d'échantillon — les chiffres sont des indicateurs de tendance, détaillés sur la <%= link_to "page méthodologie", methodologie_path, class: "underline decoration-slate-500 hover:decoration-indigo-300 text-slate-300" %>.
        </p>
      </div>

      <div class="md:col-span-5">
        <div class="bg-slate-800/50 backdrop-blur rounded-2xl p-8 border border-slate-700/50">
          <p class="text-xs font-semibold text-indigo-300 uppercase tracking-wider mb-6 text-center">Validation chambres régionales des comptes</p>
          <div class="grid grid-cols-2 gap-4 mb-6">
            <div class="text-center bg-slate-900/40 rounded-xl py-5 border border-slate-700/40">
              <div class="font-display text-4xl font-medium text-white mb-1">96 %</div>
              <div class="text-xs text-slate-400 uppercase tracking-wide">Rappel</div>
              <div class="text-[10px] text-slate-500 mt-1">fragiles détectés</div>
            </div>
            <div class="text-center bg-slate-900/40 rounded-xl py-5 border border-slate-700/40">
              <div class="font-display text-4xl font-medium text-white mb-1">71 %</div>
              <div class="text-xs text-slate-400 uppercase tracking-wide">Précision</div>
              <div class="text-[10px] text-slate-500 mt-1">alertes fondées</div>
            </div>
          </div>
          <div class="text-center text-xs text-slate-400 leading-relaxed">
            Seuil d'alerte recommandé · niveaux C, D ou E<br>
            n = 38 cas, σ ≈ ±15 pt
          </div>
        </div>
      </div>
    </div>
  </section>

  <%# ===== EN PRATIQUE ===== %>
  <section class="bg-white border-t border-slate-100">
    <div class="max-w-5xl mx-auto px-6 py-20">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-indigo-700 uppercase tracking-wider mb-3">En pratique</p>
        <h2 class="font-display text-4xl md:text-5xl font-medium text-slate-900 leading-tight tracking-tight">
          Trois étapes, du PDF à la décision.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-10">
        <div>
          <div class="font-display text-5xl text-indigo-600 font-medium mb-4">01</div>
          <h3 class="font-display text-2xl font-semibold text-slate-900 mb-3">Importer</h3>
          <p class="text-slate-600 leading-relaxed">
            Glissez-déposez les comptes annuels au format PDF (publiés par les associations au Journal officiel ou transmis directement par elles).
          </p>
        </div>
        <div>
          <div class="font-display text-5xl text-indigo-600 font-medium mb-4">02</div>
          <h3 class="font-display text-2xl font-semibold text-slate-900 mb-3">Analyser</h3>
          <p class="text-slate-600 leading-relaxed">
            Vigil'Asso extrait automatiquement les indicateurs financiers clés (rentabilité, fonds propres, trésorerie, autonomie) et calcule un score de risque.
          </p>
        </div>
        <div>
          <div class="font-display text-5xl text-indigo-600 font-medium mb-4">03</div>
          <h3 class="font-display text-2xl font-semibold text-slate-900 mb-3">Décider</h3>
          <p class="text-slate-600 leading-relaxed">
            Vous obtenez un score de A (saine) à E (fragile) et un commentaire métier. À vous de juger s'il y a lieu d'engager le dialogue avec l'association.
          </p>
        </div>
      </div>
    </div>
  </section>

  <%# ===== L'OBSERVATOIRE (option 2) ===== %>
  <section id="observatoire" class="bg-slate-50 border-t border-slate-100">
    <div class="max-w-5xl mx-auto px-6 py-20">
      <div class="grid md:grid-cols-12 gap-12 items-start">
        <div class="md:col-span-5">
          <p class="text-sm font-semibold text-indigo-700 uppercase tracking-wider mb-3">Pour aller plus loin</p>
          <h2 class="font-display text-4xl md:text-5xl font-medium text-slate-900 leading-tight tracking-tight mb-6">
            Suivre tout son portefeuille en continu.
          </h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            Pour les services Vie Associative et DAF qui souhaitent un suivi structuré sur l'ensemble de leur portefeuille subventionné, l'observatoire Vigil'Asso permet de centraliser, comparer et historiser les analyses sur la durée.
          </p>
          <a href="mailto:nicolas@vigilasso.fr?subject=Demande%20d'acc%C3%A8s%20%C3%A0%20l'observatoire%20Vigil'Asso" class="inline-flex items-center gap-2 bg-indigo-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-indigo-700 transition-colors shadow-sm">
            Demander un accès
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>

        <div class="md:col-span-7">
          <div class="bg-white rounded-xl shadow-lg border border-slate-200 overflow-hidden">
            <div class="px-5 py-3 border-b border-slate-100 flex items-center justify-between bg-slate-50">
              <span class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Mon portefeuille · 7 associations</span>
              <span class="text-xs text-slate-400">Mise à jour il y a 2 jours</span>
            </div>
            <table class="w-full text-sm">
              <tbody class="divide-y divide-slate-100">
                <tr><td class="px-4 py-2.5 text-slate-700">Centre social Les Tilleuls</td><td class="px-4 py-2.5 text-right"><span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-rose-100 text-rose-700 font-bold text-xs">D</span></td></tr>
                <tr><td class="px-4 py-2.5 text-slate-700">Maison des jeunes du quartier nord</td><td class="px-4 py-2.5 text-right"><span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-amber-100 text-amber-700 font-bold text-xs">C</span></td></tr>
                <tr><td class="px-4 py-2.5 text-slate-700">Club sportif intercommunal</td><td class="px-4 py-2.5 text-right"><span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-emerald-100 text-emerald-700 font-bold text-xs">A</span></td></tr>
                <tr><td class="px-4 py-2.5 text-slate-700">Compagnie des arts vivants</td><td class="px-4 py-2.5 text-right"><span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-emerald-100 text-emerald-700 font-bold text-xs">B</span></td></tr>
                <tr><td class="px-4 py-2.5 text-slate-700">Association d'aide aux familles</td><td class="px-4 py-2.5 text-right"><span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-amber-100 text-amber-700 font-bold text-xs">C</span></td></tr>
                <tr><td class="px-4 py-2.5 text-slate-400 text-xs italic" colspan="2">+ 2 autres associations</td></tr>
              </tbody>
            </table>
          </div>
          <p class="text-xs text-slate-400 mt-3 text-center italic">Aperçu de l'interface observatoire (sur invitation)</p>
        </div>
      </div>
    </div>
  </section>

  <%# ===== CTA FINAL ===== %>
  <section class="bg-white border-t border-slate-100">
    <div class="max-w-3xl mx-auto px-6 py-20 text-center">
      <h2 class="font-display text-4xl md:text-5xl font-medium text-slate-900 leading-tight tracking-tight mb-6">
        Tester Vigil'Asso sur un dossier.
      </h2>
      <p class="text-lg text-slate-600 leading-relaxed mb-10 max-w-xl mx-auto">
        Une association vous interroge ? Téléversez ses comptes annuels et obtenez en quelques minutes un éclairage financier indépendant.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <%= link_to new_association_path, class: "inline-flex items-center gap-2 bg-indigo-600 text-white px-6 py-3.5 rounded-lg font-semibold hover:bg-indigo-700 transition-colors shadow-sm" do %>
          Tester avec un PDF
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        <% end %>
        <a href="mailto:nicolas@vigilasso.fr" class="inline-flex items-center gap-2 text-slate-700 px-6 py-3.5 rounded-lg font-semibold hover:bg-slate-100 transition-colors">
          Échanger avec l'équipe
        </a>
      </div>
    </div>
  </section>

  <%# ===== FOOTER ===== %>
  <footer class="bg-slate-50 border-t border-slate-200">
    <div class="max-w-5xl mx-auto px-6 py-10 flex flex-wrap items-center justify-between gap-4 text-sm text-slate-500">
      <div>
        <span class="font-display font-semibold text-slate-700">Vigil'Asso</span> — outil d'aide à la décision pour les collectivités
        <span class="block text-xs text-slate-400 mt-1">Photos : Unsplash</span>
      </div>
      <div class="flex items-center gap-6">
        <a href="mailto:nicolas@vigilasso.fr" class="hover:text-slate-900 transition-colors">Contact</a>
      </div>
    </div>
  </footer>

</div>
