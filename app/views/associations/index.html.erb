<div class="mb-5">
  <h1 class="text-lg font-semibold text-slate-900">Tableau de bord</h1>
  <p class="text-sm text-slate-500">Suivi financier des associations — dataset Vigil'Asso</p>
</div>

<div class="grid grid-cols-4 gap-3 mb-5">
  <div class="bg-white border border-slate-200 rounded-xl p-4">
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-medium text-slate-500 uppercase tracking-wide">Associations</span>
      <div class="w-7 h-7 bg-indigo-50 rounded-lg flex items-center justify-center">
        <svg class="w-3.5 h-3.5 text-indigo-600" fill="currentColor" viewBox="0 0 20 20"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/></svg>
      </div>
    </div>
    <div class="text-2xl font-bold text-slate-900"><%= @stats[:total] %></div>
  </div>

  <div class="bg-white border border-slate-200 rounded-xl p-4">
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-medium text-slate-500 uppercase tracking-wide">Déficitaires</span>
      <div class="w-7 h-7 bg-red-50 rounded-lg flex items-center justify-center">
        <svg class="w-3.5 h-3.5 text-red-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
      </div>
    </div>
    <div class="text-2xl font-bold text-red-600"><%= @stats[:deficitaires] %></div>
  </div>

  <div class="bg-white border border-slate-200 rounded-xl p-4">
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-medium text-slate-500 uppercase tracking-wide">Score moyen</span>
      <div class="w-7 h-7 bg-indigo-50 rounded-lg flex items-center justify-center">
        <svg class="w-3.5 h-3.5 text-indigo-600" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
      </div>
    </div>
    <div class="text-2xl font-bold text-slate-900"><%= @stats[:score_moyen] %></div>
  </div>

  <div class="bg-white border border-slate-200 rounded-xl p-4">
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-medium text-slate-500 uppercase tracking-wide">Budget total</span>
      <div class="w-7 h-7 bg-teal-50 rounded-lg flex items-center justify-center">
        <svg class="w-3.5 h-3.5 text-teal-600" fill="currentColor" viewBox="0 0 20 20"><path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/></svg>
      </div>
    </div>
    <div class="text-2xl font-bold text-slate-900"><%= number_to_human(@stats[:budget_total], units: { thousand: "k€", million: "M€" }, precision: 1) %></div>
  </div>
</div>

<div class="bg-white border border-slate-200 rounded-xl overflow-hidden">
  <div class="px-4 py-3 border-b border-slate-100 flex items-center justify-between">
    <span class="text-sm font-medium text-slate-700">Toutes les associations</span>
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-2 text-xs text-slate-400">
        <% ["A","B","C","D","E"].each do |n| %>
          <% info = ScoringService.niveau_info(n) %>
          <% count = @associations.count { |a| a.niveau_vigi == n } %>
          <%= niveau_badge(n) %>
          <span class="mr-1"><%= count %></span>
        <% end %>
      </div>
      <span class="text-xs text-slate-400"><%= @stats[:total] %> entrée<%= @stats[:total] > 1 ? 's' : '' %></span>
    </div>
  </div>
  <table class="w-full text-sm">
    <thead>
      <tr class="bg-slate-50 border-b border-slate-100">
        <th class="text-left px-4 py-2.5 text-xs font-semibold text-slate-500 uppercase tracking-wide">Association</th>
        <th class="text-left px-4 py-2.5 text-xs font-semibold text-slate-500 uppercase tracking-wide">Clôture</th>
        <th class="text-right px-4 py-2.5 text-xs font-semibold text-slate-500 uppercase tracking-wide">Produits</th>
        <th class="text-right px-4 py-2.5 text-xs font-semibold text-slate-500 uppercase tracking-wide">Exploit.</th>
        <th class="text-right px-4 py-2.5 text-xs font-semibold text-slate-500 uppercase tracking-wide">Net</th>
        <th class="text-right px-4 py-2.5 text-xs font-semibold text-slate-500 uppercase tracking-wide">FP/Bilan</th>
        <th class="text-center px-4 py-2.5 text-xs font-semibold text-slate-500 uppercase tracking-wide">CAC</th>
        <th class="text-center px-4 py-2.5 text-xs font-semibold text-slate-500 uppercase tracking-wide">Statut</th>
        <th class="text-center px-4 py-2.5 text-xs font-semibold text-slate-500 uppercase tracking-wide">Niveau</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-50">
      <% @associations.each do |a| %>
        <tr class="hover:bg-indigo-50/40 cursor-pointer transition-colors group" onclick="location.href='<%= association_path(a) %>'">
          <td class="px-4 py-2.5">
            <div class="font-medium text-slate-900 group-hover:text-indigo-700 transition-colors"><%= a.nom %></div>
            <div class="text-xs text-slate-400"><%= a.ville %><%= " · #{a.siren}" if a.siren.present? %></div>
          </td>
          <td class="px-4 py-2.5 text-slate-500 text-xs"><%= a.cloture&.strftime("%d/%m/%Y") %></td>
          <td class="px-4 py-2.5 text-right text-slate-700 font-mono text-xs"><%= number_to_human(a.total_produits, units: { thousand: "k€", million: "M€" }, precision: 1) %></td>
          <td class="px-4 py-2.5 text-right font-mono text-xs font-medium <%= a.resultat_exploitation.to_i >= 0 ? 'text-teal-600' : 'text-red-500' %>">
            <%= a.resultat_exploitation ? "#{a.resultat_exploitation >= 0 ? '+' : ''}#{number_to_human(a.resultat_exploitation, units: { thousand: 'k€' }, precision: 1)}" : '—' %>
          </td>
          <td class="px-4 py-2.5 text-right font-mono text-xs font-medium <%= a.resultat_net.to_i >= 0 ? 'text-teal-600' : 'text-red-500' %>">
            <%= a.resultat_net ? "#{a.resultat_net >= 0 ? '+' : ''}#{number_to_human(a.resultat_net, units: { thousand: 'k€' }, precision: 1)}" : '—' %>
          </td>
          <td class="px-4 py-2.5 text-right text-xs text-slate-500"><%= a.fp_bilan_pct ? "#{a.fp_bilan_pct}%" : '—' %></td>
          <td class="px-4 py-2.5 text-center">
            <% if a.cac_certifie? %>
              <span class="inline-flex items-center text-xs bg-teal-50 text-teal-700 border border-teal-100 px-2 py-0.5 rounded-full font-medium">✓ Oui</span>
            <% else %>
              <span class="inline-flex items-center text-xs bg-slate-100 text-slate-500 px-2 py-0.5 rounded-full">Non</span>
            <% end %>
          </td>
          <td class="px-4 py-2.5 text-center">
            <% badge = { "excedent" => "bg-teal-50 text-teal-700 border border-teal-100", "deficit" => "bg-red-50 text-red-600 border border-red-100", "ambigu" => "bg-amber-50 text-amber-700 border border-amber-100" } %>
            <span class="text-xs px-2 py-0.5 rounded-full font-medium <%= badge[a.statut] || 'bg-slate-100 text-slate-500' %>"><%= a.statut %></span>
          </td>
          <td class="px-4 py-2.5 text-center">
            <div class="flex flex-col items-center gap-0.5">
              <%= niveau_badge(a.niveau_vigi, score: a.score_vigi) %>
              <%= niveau_bar(a.score_vigi) %>
            </div>
          </td>
        </tr>
      <% end %>
      <% if @associations.empty? %>
        <tr>
          <td colspan="9" class="px-4 py-16 text-center">
            <div class="flex flex-col items-center gap-3">
              <div class="w-12 h-12 bg-indigo-50 rounded-2xl flex items-center justify-center">
                <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-slate-700">Aucune association</p>
                <p class="text-xs text-slate-400 mt-0.5">Importez votre premier document comptable pour démarrer.</p>
              </div>
              <%= link_to new_association_path, class: "inline-flex items-center gap-1.5 text-sm bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 transition-colors font-medium mt-1" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Importer un PDF
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
