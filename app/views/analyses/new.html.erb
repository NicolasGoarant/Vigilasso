<div class="font-body max-w-2xl mx-auto py-10">
  <div class="mb-8 text-center">
    <p class="text-xs font-semibold text-indigo-700 uppercase tracking-wider mb-2">Analyse instantanée</p>
    <h1 class="font-display text-4xl text-slate-900 leading-tight tracking-tight">
      Évaluez la santé financière d'une association.
    </h1>
    <p class="text-slate-600 mt-3 text-lg">
      Téléversez les comptes annuels au format PDF — vous obtiendrez un score Vigil'Asso en moins d'une minute.
    </p>
  </div>

  <div data-controller="analysis-loader">
    <form data-analysis-loader-target="form"
          data-action="submit->analysis-loader#start"
          action="<%= analyser_path %>" method="post" enctype="multipart/form-data"
          class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

      <label class="block text-sm font-semibold text-slate-800 mb-3">Comptes annuels (PDF)</label>

      <label class="block border-2 border-dashed border-slate-200 rounded-xl p-10 text-center hover:border-indigo-400 hover:bg-indigo-50/30 transition-colors cursor-pointer">
        <svg class="w-12 h-12 text-slate-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        <p class="text-sm text-slate-700 font-medium mb-1">Glissez-déposez ou cliquez pour sélectionner</p>
        <p class="text-xs text-slate-400">Bilan + compte de résultat — un seul fichier PDF</p>
        <input type="file" name="pdf" accept="application/pdf" required
               data-analysis-loader-target="input"
               data-action="change->analysis-loader#preview"
               class="hidden">
      </label>

      <p data-analysis-loader-target="filename" class="mt-3 text-sm text-slate-600 hidden"></p>

      <div class="mt-4 flex items-start gap-2 bg-slate-50 rounded-lg p-3">
        <svg class="w-4 h-4 text-slate-400 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>
        <p class="text-xs text-slate-600 leading-relaxed">
          Le fichier est analysé puis <strong>immédiatement supprimé</strong> de nos serveurs.
          L'analyse est conservée 24h via un lien unique. Vous pouvez ensuite la sauvegarder en renseignant votre email.
        </p>
      </div>

      <button type="submit"
              data-analysis-loader-target="submit"
              class="w-full mt-5 inline-flex items-center justify-center gap-2 bg-indigo-600 text-white px-5 py-3 rounded-lg text-base font-semibold hover:bg-indigo-700 transition-colors disabled:opacity-60 disabled:cursor-not-allowed">
        Analyser
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </button>

      <p data-analysis-loader-target="error" class="hidden mt-3 text-sm text-red-600 bg-red-50 border border-red-100 rounded-lg px-3 py-2"></p>
    </form>

    <div data-analysis-loader-target="overlay"
         class="hidden bg-slate-900 rounded-2xl py-12 px-6 shadow-sm">
      <div class="max-w-md mx-auto text-center text-white">
        <div class="mx-auto mb-6 relative w-16 h-16">
          <div class="absolute inset-0 rounded-full border-4 border-indigo-500/30"></div>
          <div class="absolute inset-0 rounded-full border-4 border-transparent border-t-indigo-400 animate-spin"></div>
        </div>
        <h2 class="font-display text-2xl mb-1 text-white">Analyse en cours…</h2>
        <p class="text-slate-400 text-sm mb-8">Vigil'Asso étudie votre document.</p>

        <ul class="text-left space-y-3">
          <% [
            ["read", "Lecture du PDF"],
            ["extract", "Extraction des données comptables"],
            ["ratios", "Calcul des ratios financiers"],
            ["score", "Score Vigil'Asso"]
          ].each do |key, label| %>
            <li data-analysis-loader-target="step" data-step="<%= key %>"
                class="flex items-center gap-3 text-slate-400 transition-all">
              <span class="step-icon w-6 h-6 rounded-full border border-slate-700 bg-slate-800/50 flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 hidden check" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                <span class="dot w-1.5 h-1.5 rounded-full bg-slate-600"></span>
              </span>
              <span class="step-label text-sm"><%= label %></span>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
</div>
