<div class="font-body max-w-4xl mx-auto py-8">

  <div class="mb-8">
    <p class="text-xs font-semibold text-indigo-700 uppercase tracking-wider mb-2">Analyse Vigil'Asso</p>
    <h1 class="font-display text-3xl md:text-4xl text-slate-900 leading-tight tracking-tight"><%= @analysis.nom || "Association" %></h1>
    <p class="text-sm text-slate-500 mt-1">
      <%= [
        @analysis.ville,
        @analysis.siren.present? ? "SIREN #{@analysis.siren}" : nil,
        @analysis.cloture ? "Clôture #{l(@analysis.cloture, format: :long) rescue @analysis.cloture.strftime('%d/%m/%Y')}" : nil
      ].compact.join(" · ") %>
    </p>
  </div>

  <% niveau = @analysis.niveau_vigi || "E" %>
  <% niveau_info = ScoringService.niveau_info(niveau) %>

  <% commentary = @analysis.commentary_llm.is_a?(Hash) ? @analysis.commentary_llm : nil %>

  <section class="bg-white border border-slate-200 rounded-2xl p-6 md:p-10 mb-6 shadow-sm">
    <div class="text-center">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-4">Score de risque</p>
      <div class="max-w-md mx-auto mb-5">
        <%= nutriscore_gauge(niveau) %>
      </div>
      <p class="font-display text-4xl font-bold mb-1">
        <span style="color: <%= AnalysesHelper::NUTRI_COLORS[niveau] %>;"><%= niveau %></span>
        <span class="text-slate-900"> — <%= niveau_info[:text] %></span>
      </p>
      <p class="text-xl text-slate-500"><%= @analysis.score_vigi %> / 100</p>
    </div>

    <% if commentary %>
      <hr class="my-8 border-slate-200">

      <% if commentary["resume"].present? %>
        <p class="text-lg leading-relaxed text-slate-700 max-w-3xl mx-auto mb-8 text-center">
          <%= commentary["resume"] %>
        </p>
      <% end %>

      <% if commentary["forces"].is_a?(Array) && commentary["forces"].any? %>
        <div class="bg-emerald-50 rounded-lg p-6 mb-4">
          <h3 class="text-xl font-semibold text-emerald-700 mb-4 flex items-center gap-2">
            <span aria-hidden="true">✅</span> Points forts
          </h3>
          <ul class="space-y-3">
            <% commentary["forces"].each do |f| %>
              <li>
                <p class="text-base font-semibold text-slate-900"><%= f["titre"] %></p>
                <p class="text-slate-600 text-base leading-relaxed"><%= f["detail"] %></p>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% if commentary["vigilances"].is_a?(Array) && commentary["vigilances"].any? %>
        <div class="bg-amber-50 rounded-lg p-6 mb-4">
          <h3 class="text-xl font-semibold text-amber-700 mb-4 flex items-center gap-2">
            <span aria-hidden="true">⚠️</span> Points de vigilance
          </h3>
          <ul class="space-y-3">
            <% commentary["vigilances"].each do |v| %>
              <li>
                <p class="text-base font-semibold text-slate-900"><%= v["titre"] %></p>
                <p class="text-slate-600 text-base leading-relaxed"><%= v["detail"] %></p>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% if commentary["recommandations"].is_a?(Array) && commentary["recommandations"].any? %>
        <div class="bg-indigo-50 rounded-lg p-6">
          <h3 class="text-xl font-semibold text-indigo-700 mb-4 flex items-center gap-2">
            <span aria-hidden="true">🎯</span> Recommandations
          </h3>
          <ul class="space-y-3">
            <% commentary["recommandations"].each do |r| %>
              <li>
                <p class="text-slate-700 text-base leading-relaxed">
                  <span class="font-semibold text-slate-900"><%= r["horizon"].to_s.capitalize %></span>
                  <% if r["action"].present? %>
                    <span class="text-slate-500"> · </span><%= r["action"] %>
                  <% end %>
                </p>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    <% else %>
      <hr class="my-8 border-slate-200">
      <div class="max-w-3xl mx-auto text-center">
        <%= analysis_commentary(@analysis).html_safe %>
      </div>
    <% end %>
  </section>

  <% if @analysis.score_detail.present? %>
    <section class="bg-white border border-slate-200 rounded-2xl p-6 md:p-8 mb-6 shadow-sm">
      <h2 class="font-display text-2xl text-slate-900 mb-1">Détail des sous-scores</h2>
      <p class="text-sm text-slate-500 mb-6">Cinq dimensions, pondérées différemment dans le score final.</p>

      <div class="space-y-5">
        <% @analysis.score_detail.each do |key, val| %>
          <% max = AnalysesHelper::SOUS_SCORE_MAX[key] || 100 %>
          <% label = AnalysesHelper::SOUS_SCORE_LABELS[key] || key.humanize %>
          <div>
            <div class="flex justify-between items-baseline mb-1.5">
              <span class="text-base font-semibold text-slate-700"><%= label %></span>
              <span class="text-base font-mono text-slate-600"><%= val.to_f.round(1) %><span class="text-slate-400"> / <%= max %></span></span>
            </div>
            <%= sous_score_bar(val, max, niveau) %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <section class="bg-slate-50 border border-slate-200 rounded-2xl p-6 md:p-8 mb-6">
    <h2 class="font-display text-xl text-slate-900 mb-2">Comment interpréter ce score ?</h2>
    <p class="text-slate-600 leading-relaxed text-base mb-3">
      Le score Vigil'Asso (0–100) combine cinq dimensions financières issues du bilan et du compte de résultat : rentabilité, solidité du bilan, liquidité, autonomie financière et gouvernance. Il a été calibré sur 184 défaillances réelles publiées au Journal officiel et validé contre les contrôles indépendants des chambres régionales des comptes.
    </p>
    <p class="text-slate-600 leading-relaxed text-base mb-3">
      <strong>Le score n'est pas une décision.</strong> Il oriente le regard vers les dossiers qui méritent un examen approfondi.
    </p>
    <%= link_to methodologie_path, class: "inline-flex items-center gap-1.5 text-sm font-semibold text-indigo-700 hover:text-indigo-900 transition-colors" do %>
      Voir la méthodologie complète
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
    <% end %>
  </section>

  <% if @analysis.notes.present? %>
    <section class="bg-amber-50 border border-amber-100 rounded-xl p-4 mb-6 flex items-start gap-3">
      <svg width="24" height="24" class="w-6 h-6 text-amber-500 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
      <p class="flex-1 text-sm text-amber-800"><span class="font-semibold">Note d'extraction :</span> <%= @analysis.notes %></p>
    </section>
  <% end %>

  <div data-controller="save-analysis" class="flex flex-wrap items-center gap-3 mb-8">
    <% if @analysis.sauvegardee? %>
      <div class="inline-flex items-center gap-2 bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-2.5 rounded-lg text-sm font-medium">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        Analyse sauvegardée — un lien permanent a été envoyé à <%= @analysis.email %>
      </div>
    <% else %>
      <button type="button"
              data-action="click->save-analysis#open"
              class="inline-flex items-center gap-2 bg-indigo-600 text-white px-5 py-3 rounded-lg text-sm font-semibold hover:bg-indigo-700 transition-colors shadow-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        Sauvegarder cette analyse
      </button>
    <% end %>

    <%= link_to analyser_path, class: "inline-flex items-center gap-2 text-slate-700 px-5 py-3 rounded-lg text-sm font-semibold hover:bg-slate-100 transition-colors" do %>
      Analyser une autre association
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
    <% end %>

    <div data-save-analysis-target="modal"
         class="hidden fixed inset-0 z-50 bg-slate-900/70 flex items-center justify-center px-6">
      <div class="bg-white rounded-2xl p-6 max-w-md w-full shadow-2xl">
        <h3 class="font-display text-xl text-slate-900 mb-2">Recevoir le lien permanent</h3>
        <p class="text-sm text-slate-600 mb-4">Indiquez votre email : nous vous envoyons un lien unique vers cette analyse, qui ne sera plus supprimée automatiquement.</p>
        <input type="email" data-save-analysis-target="email" placeholder="vous@collectivite.fr"
               class="w-full text-sm border border-slate-200 rounded-lg px-3 py-2 mb-3 focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400 outline-none">
        <p data-save-analysis-target="error" class="hidden text-sm text-red-600 mb-3"></p>
        <div class="flex gap-2 justify-end">
          <button type="button" data-action="click->save-analysis#close"
                  class="text-sm text-slate-600 px-4 py-2 rounded-lg hover:bg-slate-100">Annuler</button>
          <button type="button"
                  data-save-analysis-target="submit"
                  data-action="click->save-analysis#submit"
                  data-url="<%= sauvegarder_analyse_path(token: @analysis.token) %>"
                  data-token="<%= form_authenticity_token %>"
                  class="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-indigo-700">Envoyer le lien</button>
        </div>
      </div>
    </div>
  </div>

  <% if @analysis.anonyme? %>
    <div class="text-center text-xs text-slate-400 italic">
      Cette analyse expire le <%= l(@analysis.expires_at, format: :long) rescue @analysis.expires_at.strftime('%d/%m/%Y à %H:%M') %>. Sauvegardez-la pour la conserver.
    </div>
  <% end %>
</div>
