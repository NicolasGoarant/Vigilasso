<% content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    .font-display { font-family: 'Fraunces', Georgia, serif; }
    .font-body    { font-family: 'Source Sans 3', system-ui, sans-serif; }
  </style>
<% end %>

<div class="font-body max-w-md mx-auto py-16">
  <div class="text-center mb-8">
    <p class="text-xs font-semibold text-indigo-700 uppercase tracking-wider mb-2">Espace collectivités</p>
    <h1 class="font-display text-3xl text-slate-900">Connexion à l'observatoire</h1>
    <p class="text-sm text-slate-500 mt-2">Réservé aux comptes activés par l'équipe Vigil'Asso.</p>
  </div>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name),
        html: { class: "bg-white border border-slate-200 rounded-2xl p-6 shadow-sm space-y-4" }) do |f| %>
    <div>
      <%= f.label :email, "Email", class: "block text-sm font-semibold text-slate-700 mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true,
            class: "w-full text-sm border border-slate-200 rounded-lg px-3 py-2 focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400 outline-none" %>
    </div>

    <div>
      <%= f.label :password, "Mot de passe", class: "block text-sm font-semibold text-slate-700 mb-1" %>
      <%= f.password_field :password, autocomplete: "current-password", required: true,
            class: "w-full text-sm border border-slate-200 rounded-lg px-3 py-2 focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400 outline-none" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <label class="flex items-center gap-2 text-sm text-slate-600">
        <%= f.check_box :remember_me, class: "rounded border-slate-300 text-indigo-600 focus:ring-indigo-300" %>
        Se souvenir de moi
      </label>
    <% end %>

    <%= f.submit "Se connecter", class: "w-full bg-indigo-600 text-white px-4 py-2.5 rounded-lg text-sm font-semibold hover:bg-indigo-700 transition-colors cursor-pointer" %>
  <% end %>

  <div class="text-center mt-4 text-sm">
    <% if devise_mapping.recoverable? && controller_name != "passwords" %>
      <%= link_to "Mot de passe oublié ?", new_password_path(resource_name), class: "text-slate-500 hover:text-slate-900" %>
    <% end %>
  </div>

  <p class="text-center text-xs text-slate-400 mt-8">
    Pas encore de compte ? <a href="mailto:nicolas@vigilasso.fr?subject=Demande%20d'acc%C3%A8s%20%C3%A0%20Vigil'Asso" class="underline hover:text-slate-700">Demander un accès</a>
  </p>
</div>
