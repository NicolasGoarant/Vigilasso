# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files (except templates).
/.env*
!/.env*.erb

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore master key for decrypting credentials and more.
/config/master.key

/app/assets/builds/*
!/app/assets/builds/.keep
data/pdfs_positifs/
data/telechargements_log.csv
data/scoring_logs/
data/pdfs_saines/
data/scoring_logs_saines/
*.bak
vigilasso_app_dump.txt
vigilasso_features.py
vigilasso_model.py
# Données du pipeline CRC : on whiteliste les CSV (résultats agrégés,
# nécessaires à /methodologie et aux scripts d'analyse), on garde les
# dossiers binaires (PDFs CRC, cache HTML) ignorés.
app/assets/fichiers_internes/*
!app/assets/fichiers_internes/data/
app/assets/fichiers_internes/data/*
!app/assets/fichiers_internes/data/*.csv
